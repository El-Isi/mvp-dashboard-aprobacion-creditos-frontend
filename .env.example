# ============================================
# Dashboard Aprobación de Créditos — Konfío
# Variables de entorno
# ============================================

# --- Aplicación ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Auth Service (Konfío) ---
# Servicio de autenticación JWT para validar sesiones de analistas
AUTH_SERVICE_URL=https://auth.konfio.mx/api/v1
AUTH_SERVICE_API_KEY=your-auth-service-api-key

# --- Notification Service (Konfío) ---
# Servicio para enviar emails transaccionales al aprobar/rechazar solicitudes
NOTIFICATIONS_URL=https://notifications.konfio.mx/api/v1
NOTIFICATIONS_API_KEY=your-notifications-api-key

# --- Solicitudes de Crédito API [GAP - No disponible aún] ---
# Descomentar cuando el servicio de solicitudes esté disponible
# CREDIT_SOLICITUDES_URL=https://creditos.konfio.mx/api/v1
# CREDIT_SOLICITUDES_API_KEY=your-credit-solicitudes-api-key

# --- Scoring Service [GAP - No disponible aún] ---
# Descomentar cuando el servicio de scoring esté disponible
# SCORING_SERVICE_URL=https://scoring.konfio.mx/api/v1
# SCORING_SERVICE_API_KEY=your-scoring-api-key
